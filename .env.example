# Mount path for deployment (without trailing slash)
# Example: if deployed to https://example.com/next-cf, set APP_PUBLIC_API_PATH=/next-cf
APP_PUBLIC_API_PATH=

# Sentry DSN — required to send events/logs. Inlined at build time into both
# the browser and server bundles. Find it in your Sentry project settings.
NEXT_PUBLIC_SENTRY_DSN=

# Optional: only needed to upload source maps during the build.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
